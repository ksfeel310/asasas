<script>
        document.addEventListener("DOMContentLoaded", function() {
            var chartDom = document.getElementById('rtChart');
            var myChart = echarts.init(chartDom);
            var option;

            // Generate some dummy R-T curve data (exponential decay)
            let data = [];
            for (let t = -40; t <= 125; t += 5) {
                // T in Kelvin
                let tempK = t + 273.15;
                // Simplified R calculation based on R25=10k, B=3435
                let r = 10 * Math.exp(3435 * (1/tempK - 1/298.15));
                data.push([t, r.toFixed(2)]);
            }

            option = {
                title: {
                    text: 'Typical R-T Curve',
                    left: 'center',
                    textStyle: { fontSize: 14, color: '#334155' }
                },
                tooltip: {
                    trigger: 'axis',
                    formatter: function (params) {
                        return 'Temp: ' + params[0].value[0] + '°C<br/>Resistance: ' + params[0].value[1] + ' kΩ';
                    }
                },
                grid: {
                    left: '3%',
                    right: '4%',
                    bottom: '10%',
                    top: '25%',
                    containLabel: true
                },
                xAxis: {
                    type: 'value',
                    name: 'Temp (°C)',
                    nameLocation: 'middle',
                    nameGap: 25,
                    min: -40,
                    max: 125,
                    axisLine: { lineStyle: { color: '#94a3b8' } }
                },
                yAxis: {
                    type: 'log',
                    name: 'Resistance (kΩ) - Log Scale',
                    axisLine: { lineStyle: { color: '#94a3b8' } },
                    splitLine: { lineStyle: { type: 'dashed', color: '#e2e8f0' } }
                },
                series: [
                    {
                        name: 'Resistance',
                        type: 'line',
                        smooth: true,
                        showSymbol: false,
                        itemStyle: { color: '#00509E' },
                        lineStyle: { width: 3 },
                        data: data
                    }
                ]
            };

            option && myChart.setOption(option);
        });
    </script>
